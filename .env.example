# Design Closet — environment configuration
# Copy this file to `.env` and fill in your values. Vite only exposes vars prefixed with VITE_.
#
# These come from Supabase → Project Settings → API.
# The anon key is safe to ship in a client bundle *as long as* Row Level Security is enabled
# (see supabase/schema.sql). It is NOT the service_role key — never put that in the client.

VITE_SUPABASE_URL=https://tifnqeujvdhhwpvhvycn.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InRpZm5xZXVqdmRoaHdwdmh2eWNuIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODQwNzUyOTQsImV4cCI6MjA5OTY1MTI5NH0.ByYeltZeU05hQl_OpprugwZrX4RNuy_X51WFs8iCO-Q

# Storage bucket that holds clothing photos (public read).
VITE_SUPABASE_BUCKET=closet-photos

# Optional: default map center for weather when geolocation is denied (Dallas, TX).
VITE_DEFAULT_LAT=32.78
VITE_DEFAULT_LON=-96.80

# Optional: Google Calendar connector. A Google Cloud OAuth 2.0 Client ID (Web).
# Public value — safe in the client. Leave blank to disable the feature.
# See README → "Google Calendar connector" for setup.
VITE_GOOGLE_CLIENT_ID=
